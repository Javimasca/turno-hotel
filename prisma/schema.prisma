generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractType {
  INDEFINIDO
  TEMPORAL
  FIJO_DISCONTINUO
  FORMACION
  PRACTICAS
  INTERINIDAD
  EVENTUAL
  OTRO
}

enum ShiftStatus {
  BORRADOR
  PUBLICADO
  CANCELADO
}

enum ShiftMasterType {
  GENERAL
  RESTAURANTE
  PISOS
}

enum AbsenceDurationMode {
  FULL_DAY
  HOURLY
  BOTH
}

enum AbsenceLegalCategory {
  SICK_LEAVE
  VACATION
  PERSONAL
  MEDICAL
  UNPAID
  OTHER
}

enum AbsenceUnit {
  FULL_DAY
  HOURLY
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum RestaurantServiceType {
  BREAKFAST
  LUNCH
  DINNER
}

enum EmployeeWorkAreaLevel {
  TRAINING
  STANDARD
  EXPERT
}

enum WeeklyDaysOffMode {
  AUTO
  FIXED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum EmployeeShiftPreferenceLevel {
  PREFERRED
  ALLOWED
  AVOID
}

enum StaffingNeedStatus {
  DRAFT
  READY
  ASSIGNED
}

model Workplace {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments              Department[]
  employeeWorkplaces       EmployeeWorkplace[]
  shifts                   Shift[]
  shiftMasters             ShiftMaster[]
  restaurantCoverageRules  RestaurantCoverageRule[]
  restaurantShiftProposals RestaurantShiftProposal[]
  roomTypes                RoomType[]
  housekeepingForecasts    HousekeepingForecast[]
  housekeepingStaffingProposals HousekeepingStaffingProposal[]
  housekeepingShiftNeeds HousekeepingShiftNeed[]

  @@index([name])
  @@map("workplaces")
}

model Department {
  id          String   @id @default(cuid())
  workplaceId String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workplace                Workplace                 @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  workAreas                WorkArea[]
  departmentJobCategories  DepartmentJobCategory[]
  departmentShiftTemplates DepartmentShiftTemplate[]
  employeeDepartments      EmployeeDepartment[]
  shifts                   Shift[]
  shiftMasters             ShiftMaster[]
  restaurantShiftProposals RestaurantShiftProposal[]
  housekeepingStaffingProposals HousekeepingStaffingProposal[]
  housekeepingShiftNeeds HousekeepingShiftNeed[]

  @@unique([workplaceId, code])
  @@unique([workplaceId, name])
  @@index([workplaceId])
  @@index([name])
  @@map("departments")
}

model WorkArea {
  id           String   @id @default(cuid())
  departmentId String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department               Department                @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  quadrantGroups           QuadrantGroup[]
  shifts                   Shift[]
  shiftMasters             ShiftMaster[]
  employeeWorkAreas        EmployeeWorkArea[]
  positions                WorkAreaPosition[]
  restaurantShiftProposals RestaurantShiftProposal[]

  @@unique([departmentId, code])
  @@unique([departmentId, name])
  @@index([departmentId, displayOrder])
  @@index([name])
  @@map("work_areas")
}

model WorkAreaPosition {
  id           String   @id @default(cuid())
  workAreaId   String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workArea WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)

  @@unique([workAreaId, code])
  @@unique([workAreaId, name])
  @@index([workAreaId, displayOrder])
  @@map("work_area_positions")
}

model QuadrantGroup {
  id           String   @id @default(cuid())
  workAreaId   String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workArea WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)

  @@unique([workAreaId, code])
  @@unique([workAreaId, name])
  @@index([workAreaId, displayOrder])
  @@index([name])
  @@map("quadrant_groups")
}

model JobCategory {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String   @unique
  shortName    String?
  description  String?
  displayOrder Int      @default(0)
  textColor    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentJobCategories DepartmentJobCategory[]
  employeeContracts       EmployeeContract[]
  shifts                  Shift[]
  shiftMasters            ShiftMaster[]

  @@index([displayOrder])
  @@index([name])
  @@map("job_categories")
}

model DepartmentJobCategory {
  id            String   @id @default(cuid())
  departmentId  String
  jobCategoryId String
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department  Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  jobCategory JobCategory @relation(fields: [jobCategoryId], references: [id], onDelete: Restrict)

  @@unique([departmentId, jobCategoryId])
  @@index([departmentId, displayOrder])
  @@index([jobCategoryId])
  @@map("department_job_categories")
}

model ShiftTemplate {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String   @unique
  shortName       String?
  description     String?
  startMinute     Int
  endMinute       Int
  crossesMidnight Boolean  @default(false)
  backgroundColor String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  departmentShiftTemplates DepartmentShiftTemplate[]

  @@index([name])
  @@map("shift_templates")
}

model DepartmentShiftTemplate {
  id              String   @id @default(cuid())
  departmentId    String
  shiftTemplateId String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Restrict)

  @@unique([departmentId, shiftTemplateId])
  @@index([departmentId])
  @@index([shiftTemplateId])
  @@map("department_shift_templates")
}

model Employee {
  id                      String   @id @default(cuid())
  code                    String   @unique
  firstName               String
  lastName                String
  email                   String?  @unique
  phone                   String?
  photoUrl                String?
  directManagerEmployeeId String?
  weeklyDaysOffMode       WeeklyDaysOffMode @default(AUTO)
  fixedDayOff1            Weekday?
  fixedDayOff2            Weekday?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  directManager       Employee?            @relation("EmployeeManager", fields: [directManagerEmployeeId], references: [id], onDelete: SetNull)
  subordinates        Employee[]           @relation("EmployeeManager")
  employeeContracts   EmployeeContract[]
  employeeWorkplaces  EmployeeWorkplace[]
  employeeDepartments EmployeeDepartment[]
  employeeWorkAreas   EmployeeWorkArea[]
  shiftPreferences    EmployeeShiftPreference[]
  availabilityBlocks EmployeeAvailabilityBlock[]
  shifts              Shift[]
  absences            Absence[]
  user                User?                @relation("UserEmployee")

  @@index([lastName, firstName])
  @@index([directManagerEmployeeId])
  @@map("employees")
}

model EmployeeWorkArea {
  id         String                @id @default(cuid())
  employeeId String
  workAreaId String
  level      EmployeeWorkAreaLevel @default(STANDARD)
  isPrimary  Boolean               @default(false)
  canLead    Boolean               @default(false)
  isActive   Boolean               @default(true)
  validFrom  DateTime              @default(now())
  validTo    DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workArea WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workAreaId, validFrom])
  @@index([employeeId])
  @@index([workAreaId])
  @@index([employeeId, isActive, validTo])
  @@index([workAreaId, isActive, validTo])
  @@map("employee_work_areas")
}

model EmployeeContract {
  id             String       @id @default(cuid())
  employeeId     String
  jobCategoryId  String
  contractType   ContractType
  startDate      DateTime
  endDate        DateTime?
  seniorityDate  DateTime?
  weeklyHours    Float?
  dailyHours     Float?
  employmentRate Float?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobCategory JobCategory @relation(fields: [jobCategoryId], references: [id], onDelete: Restrict)

  @@index([employeeId, startDate])
  @@index([employeeId, endDate])
  @@index([jobCategoryId])
  @@index([contractType])
  @@map("employee_contracts")
}

model EmployeeWorkplace {
  id          String   @id @default(cuid())
  employeeId  String
  workplaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workplace Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workplaceId])
  @@index([workplaceId])
  @@map("employee_workplaces")
}

model EmployeeShiftPreference {
  id          String                       @id @default(cuid())
  employeeId  String
  shiftMasterId String
  preference  EmployeeShiftPreferenceLevel @default(ALLOWED)
  priority    Int                          @default(0)
  isActive    Boolean                      @default(true)
  notes       String?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftMaster ShiftMaster @relation(fields: [shiftMasterId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftMasterId])
  @@index([employeeId, preference])
  @@index([shiftMasterId])
  @@index([isActive])
  @@map("employee_shift_preferences")
}

model EmployeeDepartment {
  id           String   @id @default(cuid())
  employeeId   String
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@index([departmentId])
  @@map("employee_departments")
}

model Shift {
  id            String      @id @default(cuid())
  employeeId    String
  workplaceId   String
  departmentId  String
  workAreaId    String?
  jobCategoryId String?
  shiftMasterId String?
  startAt       DateTime
  endAt         DateTime
  status        ShiftStatus @default(BORRADOR)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  workplace   Workplace    @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  workArea    WorkArea?    @relation(fields: [workAreaId], references: [id], onDelete: SetNull)
  jobCategory JobCategory? @relation(fields: [jobCategoryId], references: [id], onDelete: SetNull)
  shiftMaster ShiftMaster? @relation(fields: [shiftMasterId], references: [id], onDelete: SetNull)

  @@index([shiftMasterId])
  @@index([workAreaId])
}

model ShiftMaster {
  id                       String                    @id @default(cuid())
  code                     String
  name                     String
  description              String?
  workplaceId              String
  departmentId             String
  workAreaId               String?
  jobCategoryId            String?
  type                     ShiftMasterType           @default(GENERAL)
  startMinute              Int
  endMinute                Int
  crossesMidnight          Boolean                   @default(false)
  isPartial                Boolean                   @default(false)
  backgroundColor          String?
  effectiveCleaningMinutes Int?
  coversBreakfast          Boolean                   @default(false)
  coversLunch              Boolean                   @default(false)
  coversDinner             Boolean                   @default(false)
  countsForRoomAssignment  Boolean                   @default(false)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  restaurantShiftProposals RestaurantShiftProposal[]
  employeeShiftPreferences EmployeeShiftPreference[]
  housekeepingStaffingProposals HousekeepingStaffingProposal[]
  housekeepingShiftNeeds HousekeepingShiftNeed[]

  workplace   Workplace    @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  workArea    WorkArea?    @relation(fields: [workAreaId], references: [id], onDelete: SetNull)
  jobCategory JobCategory? @relation(fields: [jobCategoryId], references: [id], onDelete: SetNull)
  shifts      Shift[]

  @@unique([departmentId, code])
  @@unique([departmentId, name])
  @@index([workplaceId])
  @@index([departmentId])
  @@index([workAreaId])
  @@index([jobCategoryId])
  @@index([type])
  @@index([isActive])
  @@index([startMinute, endMinute])
  @@map("shift_masters")
}

model AbsenceType {
  id                 String                @id @default(cuid())
  code               String                @unique
  name               String
  description        String?
  displayOrder       Int                   @default(0)
  isActive           Boolean               @default(true)
  durationMode       AbsenceDurationMode
  requiresApproval   Boolean               @default(false)
  isPaid             Boolean               @default(true)
  blocksShifts       Boolean               @default(true)
  countsAsWorkedTime Boolean               @default(false)
  requiresDocument   Boolean               @default(false)
  allowsNotes        Boolean               @default(true)
  affectsPayroll     Boolean               @default(true)
  color              String?
  icon               String?
  legalCategory      AbsenceLegalCategory?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  absences Absence[]

  @@index([isActive])
  @@index([displayOrder])
}

model Absence {
  id            String        @id @default(cuid())
  employeeId    String
  absenceTypeId String
  unit          AbsenceUnit
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  startMinutes  Int?
  endMinutes    Int?
  status        AbsenceStatus @default(PENDING)
  notes         String?
  documentUrl   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  absenceType AbsenceType @relation(fields: [absenceTypeId], references: [id], onDelete: Restrict)

  @@index([employeeId, startDate, endDate])
  @@index([status])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  employeeId   String?   @unique
  employee     Employee? @relation("UserEmployee", fields: [employeeId], references: [id])
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RestaurantCoverageRule {
  id                     String                @id @default(cuid())
  workplaceId            String
  serviceType            RestaurantServiceType
  ratioCoversPerEmployee Int
  validFrom              DateTime
  validTo                DateTime?
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  workplace Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@index([workplaceId, serviceType, validFrom, validTo])
}

model RestaurantShiftProposal {
  id            String                @id @default(cuid())
  workplaceId   String
  departmentId  String
  workAreaId    String?
  shiftMasterId String?
  date          DateTime
  service       RestaurantServiceType
  requiredStaff Int
  covers        Int                   @default(0)
  ratioCoversPerEmployee Int?
  startAt       DateTime?
  endAt         DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  workplace   Workplace    @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  workArea    WorkArea?    @relation(fields: [workAreaId], references: [id], onDelete: Restrict)
  shiftMaster ShiftMaster? @relation(fields: [shiftMasterId], references: [id], onDelete: Restrict)

  @@index([workplaceId])
  @@index([departmentId])
  @@index([workAreaId])
  @@index([shiftMasterId])
  @@index([date])
  @@index([workplaceId, departmentId, date])
  @@map("restaurant_shift_proposals")
}

model RoomType {
  id                         String   @id @default(cuid())
  workplaceId                String
  code                       String
  name                       String
  stayoverCleaningMinutes    Int
  departureCleaningMinutes   Int
  displayOrder               Int      @default(0)
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  workplace             Workplace              @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  housekeepingForecasts HousekeepingForecast[]

  @@unique([workplaceId, code])
  @@unique([workplaceId, name])
  @@index([workplaceId, displayOrder])
  @@index([isActive])
  @@map("room_types")
}

model HousekeepingForecast {
  id          String   @id @default(cuid())
  workplaceId String
  roomTypeId  String
  date        DateTime @db.Date
  stayovers   Int      @default(0)
  departures  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workplace Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  roomType  RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([workplaceId, roomTypeId, date])
  @@index([workplaceId, date])
  @@index([roomTypeId])
  @@map("housekeeping_forecasts")
}

model HousekeepingStaffingProposal {
  id                     String   @id @default(cuid())
  workplaceId            String
  departmentId           String
  shiftMasterId          String
  date                   DateTime @db.Date
  requiredMinutes        Int
  shiftEffectiveMinutes  Int
  requiredStaff          Int
  coveredMinutes         Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  workplace   Workplace   @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  department  Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  shiftMaster ShiftMaster @relation(fields: [shiftMasterId], references: [id], onDelete: Cascade)

  @@unique([workplaceId, departmentId, shiftMasterId, date])
  @@index([workplaceId, departmentId, date])
  @@index([shiftMasterId])
  @@map("housekeeping_staffing_proposals")
}

model HousekeepingShiftNeed {
  id                    String             @id @default(cuid())
  workplaceId           String
  departmentId          String
  shiftMasterId         String
  date                  DateTime           @db.Date
  requiredStaff         Int
  assignedStaff         Int                @default(0)
  requiredMinutes       Int
  coveredMinutes        Int
  status                StaffingNeedStatus @default(DRAFT)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  workplace   Workplace   @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  department  Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  shiftMaster ShiftMaster @relation(fields: [shiftMasterId], references: [id], onDelete: Cascade)

  @@unique([workplaceId, departmentId, shiftMasterId, date])
  @@index([workplaceId, departmentId, date])
  @@index([status])
  @@map("housekeeping_shift_needs")
}

model EmployeeAvailabilityBlock {
  id         String   @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date       DateTime

  startAt    DateTime?
  endAt      DateTime?

  type       AvailabilityBlockType @default(UNAVAILABLE)
  source     AvailabilityBlockSource @default(MANUAL)

  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, date])
  @@index([date])
}

enum AvailabilityBlockType {
  DAY_OFF
  UNAVAILABLE
}

enum AvailabilityBlockSource {
  MANUAL
  AUTO_PROPOSED
}
